generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  gestor
  vendedor
  operacao
}

enum ContactStatus {
  Novo
  Qualificado
  Cliente
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(admin)
  createdAt DateTime @default(now())
}

model Contact {
  id        String        @id @default(cuid())
  name      String
  company   String
  email     String?       @unique
  phone     String?
  source    String
  owner     String
  status    ContactStatus @default(Novo)
  createdAt DateTime      @default(now())
}

model Opportunity {
  id        String   @id @default(cuid())
  title     String
  company   String
  value     Decimal  @db.Decimal(12, 2)
  owner     String
  stage     String
  closeDate DateTime
  createdAt DateTime @default(now())
}
